
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isCabinetMember(cabinetId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/cabinets/$(cabinetId)).data.members[request.auth.uid] != null;
    }

    function isTenantMember(tenantData) {
      return isSignedIn() && tenantData.members[request.auth.uid] != null;
    }

    match /cabinets/{cabinetId} {
      allow read: if isCabinetMember(cabinetId);
      allow create: if isSignedIn();
      allow update: if isCabinetMember(cabinetId) && get(/databases/$(database)/documents/cabinets/$(cabinetId)).data.members[request.auth.uid] == 'admin';
      
      match /clients/{clientId} {
        allow read, write: if isCabinetMember(cabinetId);
      }
      
      match /messages/{messageId} {
        allow read, write: if isCabinetMember(cabinetId) || 
          (isSignedIn() && get(/databases/$(database)/documents/tenants/$(resource.data.tenantId)).data.members[request.auth.uid] != null);
      }
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (resource.data.members[request.auth.uid] != null || 
        (resource.data.cabinetId != null && isCabinetMember(resource.data.cabinetId)));
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.members[request.auth.uid] != null || 
        (resource.data.cabinetId != null && isCabinetMember(resource.data.cabinetId)));
    }

    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isSignedIn() && (
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.members[request.auth.uid] != null ||
        (get(/databases/$(database)/documents/tenants/$(tenantId)).data.cabinetId != null && 
         isCabinetMember(get(/databases/$(database)/documents/tenants/$(tenantId)).data.cabinetId))
      );
    }
  }
}
