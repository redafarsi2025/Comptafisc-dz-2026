
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COMPTA-FISC DZ: SECURITY RULES (Conformité 2026)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    // Vérifie si l'utilisateur est membre du dossier (tenant)
    // On utilise get().data.get() pour éviter les erreurs si le champ 'members' est absent
    function isTenantMember(tenantId) {
      let tenant = get(/databases/$(database)/documents/tenants/$(tenantId));
      return isSignedIn() && (
        isAdmin() || 
        (tenant != null && tenant.data.get('members', {})[request.auth.uid] != null)
      );
    }

    // --- SaaS Admin Rules ---
    match /saas_admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Fiscal Engine Rules ---
    match /fiscal_laws/{fiscalLawId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_types/{fiscalVariableTypeId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /fiscal_variable_values/{fiscalVariableValueId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- DGI Watch Rules ---
    match /dgi_publications/{pubId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_scraper_status/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Business Logic Rules ---
    match /tenants/{tenantId} {
      // Accès au document du dossier lui-même
      allow read: if isSignedIn() && (isAdmin() || resource.data.get('members', {})[request.auth.uid] != null);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.get('members', {})[request.auth.uid] != null);
      allow delete: if isAdmin();

      // Accès aux sous-collections (Écritures, Factures, Salariés, etc.)
      // On combine la vérification du parent (get) et la vérification des données dénormalisées (resource.data)
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (
          isAdmin() || 
          isTenantMember(tenantId) || 
          (resource != null && resource.data.get('tenantMembers', {})[request.auth.uid] != null)
        );
        allow write: if isTenantMember(tenantId);
      }
    }
  }
}
