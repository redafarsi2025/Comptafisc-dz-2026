
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ComptaFisc-DZ Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSaaSAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSaaSAdmin());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /saas_admins/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); 
    }

    match /plans/{planId} {
      allow read: if true; // Publicly readable for pricing pages
      // Autoriser temporairement tout utilisateur connecté pour l'initialisation
      allow write: if isSignedIn(); 
    }

    match /tenants/{tenantId} {
      allow read, write: if isSignedIn(); 
      
      match /journal_entries/{entryId} {
        allow read, write: if isSignedIn();
      }
      
      match /accounts/{accountId} {
        allow read, write: if isSignedIn();
      }

      match /clients/{clientId} {
        allow read, write: if isSignedIn();
      }

      match /invoices/{invoiceId} {
        allow read, write: if isSignedIn();
      }

      match /employees/{employeeId} {
        allow read, write: if isSignedIn();
      }
      
      match /assets/{assetId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
