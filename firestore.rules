
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ComptaFisc-DZ Security Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && request.auth.uid in membersMap;
    }

    function isExistingMember(membersMap) {
      return resource != null && isMember(membersMap);
    }

    function isImmutable(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    match /tenants/{tenantId} {
      allow get, list: if isMember(resource.data.members);
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isExistingMember(resource.data.members) && isMember(request.resource.data.members);
      allow delete: if isExistingMember(resource.data.members) && resource.data.members[request.auth.uid] == 'owner';
    }

    match /tenants/{tenantId}/accounts/{accountId} {
      allow get, list: if isMember(get(/databases/$(database)/documents/tenants/$(tenantId)).data.members);
      allow create, update, delete: if isMember(get(/databases/$(database)/documents/tenants/$(tenantId)).data.members);
    }

    match /tenants/{tenantId}/journal_entries/{journalEntryId} {
      allow get, list: if isMember(resource.data.tenantMembers);
      allow create: if isMember(request.resource.data.tenantMembers) && request.resource.data.tenantId == tenantId;
      allow update: if isExistingMember(resource.data.tenantMembers) && isImmutable('tenantId');
      allow delete: if isExistingMember(resource.data.tenantMembers);
    }

    match /tenants/{tenantId}/clients/{clientId} {
      allow get, list: if isMember(resource.data.tenantMembers);
      allow create: if isMember(request.resource.data.tenantMembers) && request.resource.data.tenantId == tenantId;
      allow update: if isExistingMember(resource.data.tenantMembers) && isImmutable('tenantId');
      allow delete: if isExistingMember(resource.data.tenantMembers);
    }

    match /tenants/{tenantId}/invoices/{invoiceId} {
      allow get, list: if isMember(resource.data.tenantMembers);
      allow create: if isMember(request.resource.data.tenantMembers) && request.resource.data.tenantId == tenantId;
      allow update: if isExistingMember(resource.data.tenantMembers) && isImmutable('tenantId');
      allow delete: if isExistingMember(resource.data.tenantMembers);
    }

    match /tax_regulations/{taxRegulationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
