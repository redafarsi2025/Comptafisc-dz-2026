rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    function isMember(tenantId) {
      return isSignedIn() && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.members);
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- SaaS Admin Records ---
    match /saas_admins/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // --- Subscription Requests ---
    match /subscription_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- System Config ---
    match /system_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Customs Tariffs ---
    match /customs_tariffs/{code} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- DGI Publications ---
    match /dgi_publications/{pubId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /dgi_templates/{templateId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /fiscal_laws/{lawId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /fiscal_variable_types/{typeId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /fiscal_variable_values/{valId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /fiscal_business_rules/{ruleId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /plans/{planId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /support_tickets/{ticketId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // --- Tenant Multi-Tenancy Rules ---
    match /tenants/{tenantId} {
      allow list: if isAdmin();
      allow get, update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.members);
      allow create: if isSignedIn();
      allow delete: if isAdmin();

      // Rules for new modules
      match /assets/{assetId} {
        allow read, write: if isMember(tenantId);
      }

      match /stocks/{stockId} {
        allow read, write: if isMember(tenantId);
      }

      // Wildcard for all other subcollections
      match /{allSubcollections=**} {
        allow read, write: if isMember(tenantId);
      }
    }
  }
}
