
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COMPTA-FISC DZ: SECURITY RULES (Conformité 2026)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isAdmin() || 
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.members[request.auth.uid] != null
      );
    }

    // --- SaaS Admin Rules ---
    match /saas_admins/{userId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Fiscal Engine Rules ---
    match /fiscal_laws/{fiscalLawId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_types/{fiscalVariableTypeId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin(); 
    }

    match /fiscal_variable_values/{fiscalVariableValueId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- DGI Watch Rules ---
    match /dgi_publications/{pubId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_scraper_status/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Business Logic Rules ---
    match /tenants/{tenantId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.members[request.auth.uid] != null);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.members[request.auth.uid] != null);

      // Sub-collections logic (Journal, Invoices, Employees, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isTenantMember(tenantId);
      }
    }
  }
}
