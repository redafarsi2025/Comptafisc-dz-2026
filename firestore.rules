
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- Support Tickets ---
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- DGI Publications & Templates (Global Read) ---
    match /dgi_publications/{pubId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_laws/{lawId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_values/{valId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Plans ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- SaaS Admin Records ---
    match /saas_admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    // --- Tenant Multi-Tenancy Rules ---
    match /tenants/{tenantId} {
      // Allow list and get if member or admin. For list, a filter on members must be used in the query.
      allow get: if isSignedIn() && (isAdmin() || (resource != null && request.auth.uid in resource.data.members));
      allow list: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.members);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.members);
      allow delete: if isAdmin();

      // Rule for all subcollections (Journal, Invoices, Employees, Assets, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (
          isAdmin() || 
          request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.members
        );
      }
    }
  }
}
