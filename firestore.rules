
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ComptaFisc-DZ Security Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && request.auth.uid in membersMap;
    }

    function getTenantMembers(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data.members;
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && isMember(getTenantMembers(tenantId));
    }

    match /tenants/{tenantId} {
      allow get: if isMember(resource.data.members);
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isMember(resource.data.members) && isMember(request.resource.data.members);
      allow delete: if isMember(resource.data.members) && resource.data.members[request.auth.uid] == 'owner';
    }

    match /tenants/{tenantId}/accounts/{accountId} {
      allow read, write: if isTenantMember(tenantId);
    }

    match /tenants/{tenantId}/journal_entries/{journalEntryId} {
      allow read, write: if isTenantMember(tenantId);
    }

    match /tenants/{tenantId}/clients/{clientId} {
      allow read, write: if isTenantMember(tenantId);
    }

    match /tenants/{tenantId}/invoices/{invoiceId} {
      allow read, write: if isTenantMember(tenantId);
    }

    match /tax_regulations/{taxRegulationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
