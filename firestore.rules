
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- Support Tickets ---
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Plans & Variables ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_variable_values/{valId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- DGI Watch & Content ---
    match /dgi_publications/{pubId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dgi_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fiscal_laws/{lawId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- SaaS Admin Rules ---
    match /saas_admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Tenant Logic Rules ---
    match /tenants/{tenantId} {
      allow read, update: if isSignedIn() && (isAdmin() || resource.data.members[request.auth.uid] != null);
      allow create: if isSignedIn();
      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (
          isAdmin() || 
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.members[request.auth.uid] != null
        );
      }
    }
  }
}
