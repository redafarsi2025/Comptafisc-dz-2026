
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ComptaFisc-DZ Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSaaSAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSaaSAdmin());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /saas_admins/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Prototype: restricted to isSignedIn for bootstrapping
    }

    match /plans/{planId} {
      allow read: if true; // Publicly readable for pricing pages
      allow write: if isSaaSAdmin();
    }

    match /tenants/{tenantId} {
      allow read, write: if isSignedIn(); // Simplified for prototype
    }
  }
}
