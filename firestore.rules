rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COMPTA-FISC DZ: SECURITY RULES - PROTOTYPING VERSION
     * 
     * Note: Rules are relaxed for saas_admins and userProfiles to allow 
     * initial setup and account promotion during development.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/saas_admins/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    function isValidId(id) {
      return request.resource.data.id == id;
    }

    function isIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // --- SaaS Admin Rules ---
    match /saas_admins/{userId} {
      // Relaxed for initial setup: allow read and create for any signed-in user
      allow get, list, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn(); // Temporarily allow for initialization
    }

    // --- Fiscal Engine Rules ---
    match /fiscal_laws/{fiscalLawId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn(); // Temporarily allow for setup
    }

    match /fiscal_variable_types/{fiscalVariableTypeId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /fiscal_variable_values/{fiscalVariableValueId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Business Logic Rules ---
    match /tenants/{tenantId} {
      allow read, write: if isSignedIn() && (
        resource == null || 
        resource.data.members[request.auth.uid] != null ||
        isAdmin()
      );

      // Sub-collections logic
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.members[request.auth.uid] != null ||
          isAdmin()
        );
      }
    }
  }
}