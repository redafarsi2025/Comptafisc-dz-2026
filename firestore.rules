
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ComptaFisc-DZ Security Rules
     * Optimisées pour Next.js 15 & Multi-tenant (LF 2024-2026)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap != null && request.auth.uid in membersMap;
    }

    // Vérification de sécurité basée sur le champ tenantMembers requis dans chaque document
    function hasDocumentAccess() {
      return isSignedIn() && (
        resource == null || 
        (resource.data.tenantMembers != null && request.auth.uid in resource.data.tenantMembers)
      );
    }

    match /tenants/{tenantId} {
      allow get: if isMember(resource.data.members);
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn();
      allow update: if isMember(resource.data.members);
      allow delete: if isMember(resource.data.members) && resource.data.members[request.auth.uid] == 'owner';
    }

    // Toutes les sous-collections utilisent le pattern de sécurité par champ 'tenantMembers'
    match /tenants/{tenantId}/accounts/{accountId} {
      allow read, write: if hasDocumentAccess();
    }

    match /tenants/{tenantId}/journal_entries/{journalEntryId} {
      allow read, write: if hasDocumentAccess();
    }

    match /tenants/{tenantId}/invoices/{invoiceId} {
      allow read, write: if hasDocumentAccess();
    }

    match /tenants/{tenantId}/assets/{assetId} {
      allow read, write: if hasDocumentAccess();
    }

    match /tenants/{tenantId}/employees/{employeeId} {
      allow read, write: if hasDocumentAccess();
    }

    match /tax_regulations/{taxRegulationId} {
      allow get, list: if isSignedIn();
    }
  }
}
