
{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Représente une entité comptable ou un dossier d'entreprise dans ComptaFisc-DZ.",
      "properties": {
        "id": { "type": "string" },
        "raisonSociale": { "type": "string", "description": "Dénomination officielle (CNRC)" },
        "formeJuridique": { "type": "string", "enum": ["SARL", "SPA", "EI", "SNC", "EURL", "Auto-entrepreneur"] },
        "nif": { "type": "string", "description": "Numéro d'Identification Fiscale (15 chiffres)" },
        "nis": { "type": "string", "description": "Numéro d'Identification Statistique" },
        "registreCommerce": { "type": "string", "description": "Format: WW/YY/BXXXXXX" },
        "articleImposition": { "type": "string" },
        "dateCreation": { "type": "string", "format": "date-time" },
        "capitalSocial": { "type": "number" },
        "adresse": {
          "type": "object",
          "properties": {
            "rue": { "type": "string" },
            "commune": { "type": "string" },
            "wilaya": { "type": "string" }
          }
        },
        "telephone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "siteWeb": { "type": "string" },
        "regimeFiscal": { "type": "string", "enum": ["IFU", "REGIME_REEL_SIMPLIFIE", "REGIME_REEL"] },
        "assujettissementTva": { "type": "boolean" },
        "tauxTvaApplicable": { "type": "string", "enum": ["TVA_19", "TVA_9", "TVA_EXONERE"] },
        "periodiciteDeclaration": { "type": "string", "enum": ["MENSUEL", "TRIMESTRIEL", "ANNUEL"] },
        "activiteNAP": { "type": "string", "description": "Code Nomenclature des Activités" },
        "secteurActivite": { "type": "string", "enum": ["COMMERCE", "PRODUCTION", "SERVICES", "BTP", "AGRICULTURE"] },
        "centreImpots": { "type": "string" },
        "exerciceFiscal": {
          "type": "object",
          "properties": {
            "debut": { "type": "string", "format": "date-time" },
            "fin": { "type": "string", "format": "date-time" }
          }
        },
        "effectif": { "type": "number" },
        "plan": { "type": "string", "enum": ["GRATUIT", "ESSENTIEL", "PRO", "CABINET"] },
        "subscription": {
          "type": "object",
          "properties": {
            "statut": { "type": "string", "enum": ["ACTIF", "ESSAI", "SUSPENDU", "EXPIRE", "RESILIE"] },
            "dateDebut": { "type": "string", "format": "date-time" },
            "dateExpiration": { "type": "string", "format": "date-time" }
          }
        },
        "addOns": { "type": "array", "items": { "type": "string" } },
        "efatura": {
          "type": "object",
          "properties": {
            "active": { "type": "boolean" },
            "prefixeFacture": { "type": "string" },
            "dernierNumero": { "type": "number" }
          }
        },
        "members": { "type": "object", "description": "Map des UIDs vers les rôles" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/tenants/{tenantId}",
        "definition": {
          "entityName": "Tenant",
          "schema": { "$ref": "#/backend/entities/Tenant" },
          "description": "Dossier fiscal complet du client."
        }
      }
    ]
  }
}
