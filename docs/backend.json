
{
  "entities": {
    "FiscalLaw": {
      "title": "FiscalLaw",
      "type": "object",
      "description": "Référentiel des versions législatives (ex: LF 2026).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" },
        "publicationDate": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    },
    "FiscalVariableType": {
      "title": "FiscalVariableType",
      "type": "object",
      "description": "Définition globale d'une variable (ex: SNMG, TVA_STD).",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "dataType": { "type": "string", "enum": ["number", "string", "json"] }
      }
    },
    "FiscalVariableValue": {
      "title": "FiscalVariableValue",
      "type": "object",
      "description": "Valeur versionnée par loi et par date.",
      "properties": {
        "fiscalVariableTypeId": { "type": "string" },
        "fiscalLawId": { "type": "string" },
        "value": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" }
      }
    },
    "FiscalBusinessRule": {
      "title": "FiscalBusinessRule",
      "type": "object",
      "description": "Règle métier DSL (Calculateur dynamique).",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["COMPTA", "SOCIAL", "FISCAL"] },
        "priority": { "type": "number" },
        "when": { "type": "string", "description": "Condition d'application DSL (ex: secteur == 'BTP')" },
        "then": { "type": "array", "description": "Actions de calcul" },
        "justify": { "type": "string", "description": "Référence article CIDTA" },
        "active": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/fiscal_laws/{lawId}": { "schema": "#/backend/entities/FiscalLaw", "description": "Versions législatives" },
    "/fiscal_variable_types/{typeId}": { "schema": "#/backend/entities/FiscalVariableType", "description": "Référentiel variables" },
    "/fiscal_variable_values/{valId}": { "schema": "#/backend/entities/FiscalVariableValue", "description": "Valeurs versionnées" },
    "/fiscal_business_rules/{ruleId}": { "schema": "#/backend/entities/FiscalBusinessRule", "description": "Moteur DSL Master" }
  }
}
