
{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Dossier fiscal complet du client (35 variables).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "formeJuridique": { "type": "string", "enum": ["SARL", "SPA", "EI", "SNC", "EURL", "Auto-entrepreneur", "Personne physique"] },
        "nif": { "type": "string" },
        "nis": { "type": "string" },
        "registreCommerce": { "type": "string" },
        "articleImposition": { "type": "string" },
        "dateCreation": { "type": "string", "format": "date-time" },
        "capitalSocial": { "type": "number" },
        "adresse": {
          "type": "object",
          "properties": {
            "rue": { "type": "string" },
            "commune": { "type": "string" },
            "wilaya": { "type": "string" }
          }
        },
        "telephone": { "type": "string" },
        "email": { "type": "string" },
        "siteWeb": { "type": "string" },
        "regimeFiscal": { "type": "string", "enum": ["IFU", "REGIME_REEL_SIMPLIFIE", "REGIME_REEL"] },
        "assujettissementTva": { "type": "boolean" },
        "tauxTvaApplicable": { "type": "string", "enum": ["TVA_19", "TVA_9", "TVA_EXONERE"] },
        "periodiciteDeclaration": { "type": "string", "enum": ["MENSUEL", "TRIMESTRIEL", "ANNUEL"] },
        "activiteNAP": { "type": "string" },
        "secteurActivite": { "type": "string", "enum": ["COMMERCE", "PRODUCTION", "SERVICES", "BTP", "AGRICULTURE"] },
        "centreImpots": { "type": "string" },
        "exerciceFiscal": {
          "type": "object",
          "properties": {
            "debut": { "type": "string" },
            "fin": { "type": "string" }
          }
        },
        "effectif": { "type": "number" },
        "plan": { "type": "string" },
        "subscription": {
          "type": "object",
          "properties": {
            "statut": { "type": "string" },
            "dateDebut": { "type": "string" },
            "dateExpiration": { "type": "string" }
          }
        },
        "members": { "type": "object" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "totalAmountExcludingTax": { "type": "number" },
        "totalTaxAmount": { "type": "number" },
        "totalStampDutyAmount": { "type": "number" },
        "totalAmountIncludingTax": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Account": {
      "title": "Custom Account (PCE)",
      "description": "Sous-compte personnalisé créé par l'entité.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "rootCode": { "type": "string" },
        "class": { "type": "number" },
        "tenantId": { "type": "string" }
      }
    },
    "Asset": {
      "title": "Asset (Immobilisation)",
      "description": "Élément d'actif immobilisé.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "designation": { "type": "string" },
        "acquisitionValue": { "type": "number" },
        "amortizationRate": { "type": "number" }
      }
    },
    "Employee": {
      "title": "Employee",
      "description": "Fiche salarié pour le livre de paye.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "baseSalary": { "type": "number" },
        "primes": { "type": "number" },
        "cnasNumber": { "type": "string" },
        "hireDate": { "type": "string", "format": "date" },
        "tenantId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "#/entities/Tenant",
      "description": "Données de base du dossier"
    },
    "/tenants/{tenantId}/invoices/{invoiceId}": {
      "schema": "#/entities/Invoice",
      "description": "Factures clients du dossier"
    },
    "/tenants/{tenantId}/accounts/{accountId}": {
      "schema": "#/entities/Account",
      "description": "Plan de comptes personnalisé"
    },
    "/tenants/{tenantId}/assets/{assetId}": {
      "schema": "#/entities/Asset",
      "description": "Registre des immobilisations"
    },
    "/tenants/{tenantId}/employees/{employeeId}": {
      "schema": "#/entities/Employee",
      "description": "Registre du personnel"
    }
  }
}
