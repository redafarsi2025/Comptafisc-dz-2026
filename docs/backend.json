
{
  "entities": {
    "FiscalLaw": {
      "title": "FiscalLaw",
      "type": "object",
      "description": "Référentiel des lois de finances et décrets sources.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" },
        "publicationDate": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    },
    "FiscalVariableType": {
      "title": "FiscalVariableType",
      "type": "object",
      "description": "Définition d'une variable (ex: SNMG, TVA_STD).",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "dataType": { "type": "string", "enum": ["number", "string", "json"] }
      }
    },
    "FiscalVariableValue": {
      "title": "FiscalVariableValue",
      "type": "object",
      "description": "Valeur historisée d'une variable.",
      "properties": {
        "fiscalVariableTypeId": { "type": "string" },
        "fiscalLawId": { "type": "string" },
        "value": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" }
      }
    },
    "FiscalBusinessRule": {
      "title": "FiscalBusinessRule",
      "type": "object",
      "description": "Règle de calcul complexe (IRG, IFU).",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string", "enum": ["COMPTA", "SOCIAL", "FISCAL"] },
        "order": { "type": "number", "description": "Priorité d'exécution (le plus bas en premier)." },
        "dependsOn": { "type": "array", "items": { "type": "string" }, "description": "Codes des règles dont cette règle dépend." },
        "effectiveStartDate": { "type": "string", "format": "date" },
        "brackets": { "type": "array" },
        "formula": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/fiscal_laws/{lawId}": { "schema": "#/backend/entities/FiscalLaw", "description": "Lois sources" },
    "/fiscal_variable_types/{typeId}": { "schema": "#/backend/entities/FiscalVariableType", "description": "Types de variables" },
    "/fiscal_variable_values/{valId}": { "schema": "#/backend/entities/FiscalVariableValue", "description": "Historique des valeurs" },
    "/fiscal_business_rules/{ruleId}": { "schema": "#/backend/entities/FiscalBusinessRule", "description": "Moteur de règles" }
  }
}
