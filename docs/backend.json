
{
  "entities": {
    "Asset": {
      "title": "Asset",
      "type": "object",
      "description": "Fiche immobilisation experte conforme SCF.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Code unique immo" },
        "designation": { "type": "string" },
        "category": { "type": "string", "enum": ["204", "211", "213", "215", "2182", "2183", "2184"] },
        "serialNumber": { "type": "string" },
        "acquisitionDate": { "type": "string", "format": "date" },
        "serviceDate": { "type": "string", "format": "date" },
        "acquisitionValue": { "type": "number" },
        "residualValue": { "type": "number", "default": 0 },
        "amortizationRate": { "type": "number" },
        "amortizationType": { "type": "string", "enum": ["LINEAR", "DEGRESSIVE"], "default": "LINEAR" },
        "physicalStatus": { "type": "string", "enum": ["GOOD", "USED", "HS", "REFORM"] },
        "physicalLocation": { "type": "string" },
        "assignedEmployee": { "type": "string" },
        "tenantId": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fiche article expert ERP (Logistique + Compta + Inventaire).",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Code article unique" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["MARCHANDISE", "MATIERE_PREMIERE", "PRODUIT_FINI", "CONSOMMABLE"] },
        "unit": { "type": "string", "default": "U" },
        "theoreticalStock": { "type": "number", "default": 0 },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "tenantId": { "type": "string" }
      }
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "type": "object",
      "description": "Commande client (CC).",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["DRAFT", "VALIDATED", "SHIPPED", "INVOICED", "CANCELLED"] },
        "totalHT": { "type": "number" },
        "totalTVA": { "type": "number" },
        "totalTTC": { "type": "number" },
        "items": { "type": "array" }
      }
    },
    "DeliveryNote": {
      "title": "DeliveryNote",
      "type": "object",
      "description": "Bon de Livraison (BL).",
      "properties": {
        "id": { "type": "string" },
        "deliveryNumber": { "type": "string" },
        "orderId": { "type": "string" },
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "items": { "type": "array" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/tenants/{tenantId}/sales_orders": { "schema": "#/backend/entities/SalesOrder", "description": "Commandes clients" },
    "/tenants/{tenantId}/delivery_notes": { "schema": "#/backend/entities/DeliveryNote", "description": "Bons de livraison" },
    "/tenants/{tenantId}/customer_invoices": { "schema": "object", "description": "Factures clients" },
    "/tenants/{tenantId}/customer_returns": { "schema": "object", "description": "Retours clients" },
    "/tenants/{tenantId}/customer_credit_notes": { "schema": "object", "description": "Avoirs clients" }
  }
}
