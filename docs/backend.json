
{
  "entities": {
    "Cabinet": {
      "title": "Accounting Firm (Cabinet)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "object", "description": "Map of userIds to roles (admin, accountant)" },
        "createdAt": { "type": "string" }
      }
    },
    "ManagedClient": {
      "title": "Cabinet Client Link",
      "description": "Relationship between cabinet and tenant.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "fiscalStatus": { "type": "string", "enum": ["Up to date", "Pending", "Late"] },
        "lastG50Date": { "type": "string" }
      }
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Dossier fiscal complet du client (35 variables).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "cabinetId": { "type": "string", "description": "Link to the accounting firm" },
        "formeJuridique": { "type": "string", "enum": ["SARL", "SPA", "EI", "SNC", "EURL", "Auto-entrepreneur", "Personne physique"] },
        "nif": { "type": "string" },
        "nis": { "type": "string" },
        "registreCommerce": { "type": "string" },
        "adresse": {
          "type": "object",
          "properties": {
            "rue": { "type": "string" },
            "commune": { "type": "string" },
            "wilaya": { "type": "string" }
          }
        },
        "regimeFiscal": { "type": "string", "enum": ["IFU", "REGIME_REEL_SIMPLIFIE", "REGIME_REEL"] },
        "assujettissementTva": { "type": "boolean" },
        "members": { "type": "object" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "CabinetMessage": {
      "title": "Collaboration Message",
      "type": "object",
      "properties": {
        "cabinetId": { "type": "string" },
        "tenantId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/cabinets/{cabinetId}": {
      "schema": "#/entities/Cabinet"
    },
    "/cabinets/{cabinetId}/clients/{tenantId}": {
      "schema": "#/entities/ManagedClient"
    },
    "/cabinets/{cabinetId}/messages": {
      "schema": "#/entities/CabinetMessage"
    },
    "/tenants/{tenantId}": {
      "schema": "#/entities/Tenant"
    }
  }
}
