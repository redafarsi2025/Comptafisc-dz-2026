{
  "entities": {
    "CustomsTariff": {
      "title": "CustomsTariff",
      "type": "object",
      "description": "Référentiel SH10 pour la nomenclature douanière.",
      "properties": {
        "code": { "type": "string" },
        "label": { "type": "string" },
        "duty": { "type": "number", "description": "Droit de douane (%)" },
        "daps": { "type": "number", "description": "Additionnel provisoire (%)" },
        "tva": { "type": "number", "description": "TVA Import (%)" },
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CustomsParams": {
      "title": "CustomsParams",
      "type": "object",
      "description": "Paramètres globaux de liquidation douanière.",
      "properties": {
        "tcs_rate": { "type": "number" },
        "prct_rate": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AccountTemplate": {
      "title": "AccountTemplate",
      "type": "object",
      "description": "Modèle de plan comptable par secteur d'activité.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sector": { "type": "string", "enum": ["COMMERCE", "INDUSTRIE", "SERVICES", "BTP", "TRANSPORT", "AGRICULTURE"] },
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "ClientAccount": {
      "title": "ClientAccount",
      "type": "object",
      "description": "Instance d'un compte comptable pour un dossier spécifique.",
      "properties": {
        "id": { "type": "string" },
        "accountNumber": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["ACTIF", "PASSIF", "CHARGE", "PRODUIT"] },
        "class": { "type": "number" },
        "templateOriginId": { "type": "string" },
        "isCustom": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "parentNumber": { "type": "string" }
      }
    },
    "SubscriptionRequest": {
      "title": "SubscriptionRequest",
      "type": "object",
      "description": "Demande de souscription à un service premium en attente de validation admin.",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "addonId": { "type": "string" },
        "addonName": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/customs_tariffs/{code}": { "schema": "#/backend/entities/CustomsTariff", "description": "Nomenclature SH10" },
    "/system_config/customs_params": { "schema": "#/backend/entities/CustomsParams", "description": "Taux douaniers globaux" },
    "/tenants/{tenantId}/accounts/{accId}": { "schema": "#/backend/entities/ClientAccount", "description": "Plan comptable personnalisé" },
    "/subscription_requests/{requestId}": { "schema": "#/backend/entities/SubscriptionRequest", "description": "Demandes d'activation premium" }
  }
}