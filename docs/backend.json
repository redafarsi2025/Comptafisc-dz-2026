
{
  "entities": {
    "FiscalLaw": {
      "title": "FiscalLaw",
      "type": "object",
      "description": "Représente une loi de finances ou réglementation fiscale.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date-time" },
        "publicationDate": { "type": "string", "format": "date-time" }
      }
    },
    "DgiTemplate": {
      "title": "DgiTemplate",
      "type": "object",
      "description": "Template de formulaire officiel DGI avec mapping IA et fond de document.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["G50", "G12", "G4", "ANNEXE"] },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "backgroundImage": { "type": "string", "description": "Contenu du document en Base64" },
              "fields": { "type": "array" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/fiscal_laws/{lawId}": {
      "schema": "#/backend/entities/FiscalLaw",
      "description": "Lois de finances globales."
    },
    "/dgi_templates/{templateId}": {
      "schema": "#/backend/entities/DgiTemplate",
      "description": "Templates de formulaires stockés en base."
    },
    "/tenants/{tenantId}": {
      "schema": "object",
      "description": "Dossiers clients."
    }
  }
}
