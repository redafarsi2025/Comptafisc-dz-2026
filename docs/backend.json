
{
  "entities": {
    "Asset": {
      "title": "Asset",
      "type": "object",
      "description": "Fiche immobilisation experte conforme SCF.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Code unique immo" },
        "designation": { "type": "string" },
        "category": { "type": "string", "enum": ["204", "211", "213", "215", "2182", "2183", "2184"] },
        "serialNumber": { "type": "string" },
        "acquisitionDate": { "type": "string", "format": "date" },
        "serviceDate": { "type": "string", "format": "date" },
        "acquisitionValue": { "type": "number" },
        "residualValue": { "type": "number", "default": 0 },
        "amortizationRate": { "type": "number" },
        "amortizationType": { "type": "string", "enum": ["LINEAR", "DEGRESSIVE"], "default": "LINEAR" },
        "physicalStatus": { "type": "string", "enum": ["GOOD", "USED", "HS", "REFORM"] },
        "physicalLocation": { "type": "string" },
        "assignedEmployee": { "type": "string" },
        "tenantId": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fiche article expert ERP (Logistique + Compta + Inventaire).",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Code article unique" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "name2": { "type": "string", "description": "Désignation multilingue" },
        "family": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "type": { "type": "string", "enum": ["MARCHANDISE", "MATIERE_PREMIERE", "PRODUIT_FINI", "CONSOMMABLE"] },
        "unit": { "type": "string", "default": "U" },
        "minStock": { "type": "number", "default": 0 },
        "maxStock": { "type": "number" },
        "securityStock": { "type": "number", "default": 0 },
        "leadTimeDays": { "type": "number", "description": "Délai appro" },
        "valuationMethod": { "type": "string", "enum": ["CMUP", "FIFO"], "default": "CMUP" },
        "mainWarehouse": { "type": "string" },
        "locationBin": { "type": "string", "description": "Allée/Casier" },
        "purchasePrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "tvaRate": { "type": "number", "default": 19 },
        "theoreticalStock": { "type": "number", "default": 0 },
        "lastInventoryDate": { "type": "string", "format": "date-time" },
        "stockAccount": { "type": "string", "description": "Compte classe 3" },
        "variationAccount": { "type": "string", "default": "603" },
        "tenantId": { "type": "string" }
      }
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "type": "object",
      "description": "Bon de commande fournisseur.",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["DRAFT", "VALIDATED", "RECEIVED", "INVOICED", "CANCELLED"] },
        "totalHT": { "type": "number" },
        "totalTVA": { "type": "number" },
        "totalTTC": { "type": "number" },
        "items": { "type": "array" }
      }
    },
    "SupplierInvoice": {
      "title": "SupplierInvoice",
      "type": "object",
      "description": "Facture fournisseur avec rapprochement 3-way.",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "orderId": { "type": "string" },
        "receiptId": { "type": "string" },
        "supplierId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amountHT": { "type": "number" },
        "amountTVA": { "type": "number" },
        "amountTTC": { "type": "number" },
        "isMatched": { "type": "boolean" },
        "paymentStatus": { "type": "string", "enum": ["UNPAID", "PARTIAL", "PAID"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/fiscal_laws/{lawId}": { "schema": "object", "description": "Lois de finances" },
    "/dgi_templates/{templateId}": { "schema": "object", "description": "Templates formulaires" },
    "/support_tickets/{ticketId}": { "schema": "object", "description": "Tickets support" },
    "/tenants/{tenantId}": { "schema": "object", "description": "Dossiers clients" },
    "/tenants/{tenantId}/assets/{assetId}": { "schema": "#/backend/entities/Asset", "description": "Registre des immobilisations" },
    "/tenants/{tenantId}/products/{productId}": { "schema": "#/backend/entities/Product", "description": "Catalogue articles" },
    "/tenants/{tenantId}/inventory_sessions/{sessionId}": { "schema": "#/backend/entities/InventorySession", "description": "Sessions d'inventaire" },
    "/tenants/{tenantId}/purchase_orders/{orderId}": { "schema": "#/backend/entities/PurchaseOrder", "description": "Bons de commande" },
    "/tenants/{tenantId}/supplier_invoices/{invoiceId}": { "schema": "#/backend/entities/SupplierInvoice", "description": "Factures fournisseurs" }
  }
}
