
{
  "entities": {
    "AccountTemplate": {
      "title": "AccountTemplate",
      "type": "object",
      "description": "Modèle de plan comptable par secteur d'activité.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sector": { "type": "string", "enum": ["COMMERCE", "INDUSTRIE", "SERVICES", "BTP", "TRANSPORT", "AGRICULTURE"] },
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "ClientAccount": {
      "title": "ClientAccount",
      "type": "object",
      "description": "Instance d'un compte comptable pour un dossier spécifique.",
      "properties": {
        "id": { "type": "string" },
        "accountNumber": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["ACTIF", "PASSIF", "CHARGE", "PRODUIT"] },
        "class": { "type": "number" },
        "templateOriginId": { "type": "string" },
        "isCustom": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "parentNumber": { "type": "string" }
      }
    },
    "FiscalLaw": {
      "title": "FiscalLaw",
      "type": "object",
      "description": "Référentiel des versions législatives (ex: LF 2026).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" },
        "publicationDate": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    },
    "FiscalVariableType": {
      "title": "FiscalVariableType",
      "type": "object",
      "description": "Définition globale d'une variable (ex: SNMG, TVA_STD, VALEUR_POINT).",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "dataType": { "type": "string", "enum": ["number", "string", "json"] }
      }
    },
    "FiscalVariableValue": {
      "title": "FiscalVariableValue",
      "type": "object",
      "description": "Valeur versionnée par loi et par date.",
      "properties": {
        "fiscalVariableTypeId": { "type": "string" },
        "fiscalLawId": { "type": "string" },
        "value": { "type": "string" },
        "effectiveStartDate": { "type": "string", "format": "date" }
      }
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "description": "Fiche employé avec paramètres indiciaires.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nin": { "type": "string" },
        "cnasNumber": { "type": "string" },
        "position": { "type": "string" },
        "indice": { "type": "number" },
        "echelon": { "type": "number" },
        "primesImposables": { "type": "number" },
        "indemnitePanier": { "type": "number" },
        "indemniteTransport": { "type": "number" },
        "isGrandSud": { "type": "boolean" },
        "isHandicapped": { "type": "boolean" }
      }
    },
    "Payroll": {
      "title": "Payroll",
      "type": "object",
      "description": "Calcul mensuel de paie.",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "period": { "type": "string" },
        "salaireBase": { "type": "number" },
        "salairePoste": { "type": "number" },
        "cnas": { "type": "number" },
        "irg": { "type": "number" },
        "net": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/fiscal_laws/{lawId}": { "schema": "#/backend/entities/FiscalLaw", "description": "Versions législatives" },
    "/fiscal_variable_types/{typeId}": { "schema": "#/backend/entities/FiscalVariableType", "description": "Référentiel variables" },
    "/fiscal_variable_values/{valId}": { "schema": "#/backend/entities/FiscalVariableValue", "description": "Valeurs versionnées" },
    "/tenants/{tenantId}/accounts/{accId}": { "schema": "#/backend/entities/ClientAccount", "description": "Plan comptable personnalisé du client" },
    "/tenants/{tenantId}/employees/{empId}": { "schema": "#/backend/entities/Employee", "description": "Dossier personnel" },
    "/tenants/{tenantId}/payroll/{payId}": { "schema": "#/backend/entities/Payroll", "description": "Journal de paie" }
  }
}
